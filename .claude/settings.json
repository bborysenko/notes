{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "npx tsx .claude/hooks/write-boundary.ts",
            "statusMessage": "Checking write boundary..."
          }
        ]
      }
    ]
  }
}
